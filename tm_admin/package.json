{
  "name": "talentmaster-admin",
  "version": "1.0.0",
  "dependencies": {
    "firebase-admin": "^12.0.0"
  }
}
const admin = require('firebase-admin');
const serviceAccount = require('./serviceAccountKey.json');

admin.initializeApp({
  credential: admin.credential.cert(serviceAccount)
});

const db   = admin.firestore();
const auth = admin.auth();

const SEURAT = [
  { id:'fcl',        nimi:'FC Lahti Juniorit',  vp_uid:'dpYcfa154ZOHshZzHrVaTZ2iTHE3', vp_email:'vp.fcl@talentmaster.fi',        kaupunki:'Lahti'    },
  { id:'kpv',        nimi:'KPV',                vp_uid:'jIbW7q8nLggswTjefkYuSvtneH92', vp_email:'vp.kpv@talentmaster.fi',        kaupunki:'Kokkola'  },
  { id:'palloiirot', nimi:'Pallo-Iirot',         vp_uid:'fBf1c60rjXTPxYlsV03EfrHZ2xM2', vp_email:'vp.palloiirot@talentmaster.fi', kaupunki:'Iisalmi'  },
  { id:'yvies',      nimi:'Ylöjärven Ilves',     vp_uid:'U21RwOm7OYdrAQB8wTXXlDQksEk2', vp_email:'vp.yvies@talentmaster.fi',      kaupunki:'Ylöjärvi' },
  { id:'sjk',        nimi:'SJK Juniorit',        vp_uid:'1eHyfKsuTSRAAsPu9kRZ22E4hwo2', vp_email:'vp.sjk@talentmaster.fi',        kaupunki:'Seinäjoki'},
  { id:'grifk',      nimi:'GrIFK',               vp_uid:'lBCx0ivDYVWLmxD9TGKsvYrFrlo1', vp_email:'vp.grifk@talentmaster.fi',      kaupunki:'Helsinki' }
];

async function alustaKaikkiSeurat() {
  console.log('TalentMaster — Seurojen alustus alkaa...\n');
  for (const seura of SEURAT) {
    try {
      console.log('Alustetaan: ' + seura.nimi);
      
      await db.collection('seurat').doc(seura.id).set({
        id:          seura.id,
        nimi:        seura.nimi,
        laji:        'jalkapallo',
        paketti:     'kehitystaso',
        vp_uid:      seura.vp_uid,
        vp_email:    seura.vp_email,
        kaupunki:    seura.kaupunki,
        maa:         'FI',
        aktiivinen:  true,
        luotu:       admin.firestore.FieldValue.serverTimestamp(),
        ominaisuudet: ['kirjaukset','testit','pelaajaprofiilit','adar','biologinen_ika','talenttiohjelma'],
        roolit:      ['vp','valmentaja','testivastaava','talenttivalmentaja','fysiikkavalmentaja'],
        max_pelaajia: 300,
        tilastot:    { pelaajia:0, joukkueita:0, kirjauksia:0 }
      }, { merge: true });

      await auth.setCustomUserClaims(seura.vp_uid, {
        seura:   seura.id,
        rooli:   'valmennuspäällikkö',
        paketti: 'kehitystaso',
        laji:    'jalkapallo',
        admin:   false
      });

      console.log('OK: ' + seura.nimi + '\n');
    } catch(e) {
      console.error('VIRHE ' + seura.id + ': ' + e.message);
    }
  }
  console.log('Kaikki seurat alustettu!');
  process.exit(0);
}

alustaKaikkiSeurat().catch(function(e) {
  console.error('Kriittinen virhe:', e);
  process.exit(1);
});
