rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── APUFUNKTIOT ──────────────────────────────────────────────────────────

    function onKirjautunut() {
      return request.auth != null;
    }

    function onSuperAdmin() {
      return onKirjautunut() && (
        request.auth.token.superAdmin == true ||
        request.auth.token.email == 'talentmasterid@gmail.com'
      );
    }

    // Seuran Admin: hallinnollinen rooli joka hoitaa joukkueet,
    // käyttäjäkutsut ja pelaajien tuonnin. Tunnistetaan
    // seurat/{seuraId}/kayttajat/{uid} -dokumentin rooli-kentästä.
    function onSeuranAdmin(seuraId) {
      return onKirjautunut() && (
        onSuperAdmin() ||
        (exists(/databases/$(database)/documents/seurat/$(seuraId)/kayttajat/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/seurat/$(seuraId)/kayttajat/$(request.auth.uid)).data.rooli == 'seuran_admin')
      );
    }

    // VP tunnistetaan seura-dokumentin vp_uid-kentästä
    function onSeuranVP(seuraId) {
      return onKirjautunut() &&
        request.auth.uid == get(/databases/$(database)/documents/seurat/$(seuraId)).data.vp_uid;
    }

    // Seuran jäsen = Super Admin TAI VP TAI rekisteröity käyttäjä
    function onSeuranJasen(seuraId) {
      return onKirjautunut() && (
        onSuperAdmin() ||
        onSeuranVP(seuraId) ||
        exists(/databases/$(database)/documents/seurat/$(seuraId)/kayttajat/$(request.auth.uid))
      );
    }

    // Hallinnollinen oikeus = Super Admin TAI Seuran Admin TAI VP
    // VP sisällytetään koska hän saattaa kutsua valmentajia
    function onHallinnollinen(seuraId) {
      return onSuperAdmin() || onSeuranAdmin(seuraId) || onSeuranVP(seuraId);
    }

    // ── ADMINS-KOKOELMA ──────────────────────────────────────────────────────

    match /admins/{uid} {
      allow read:  if onKirjautunut() && request.auth.uid == uid;
      allow write: if false; // Vain Firebase Admin SDK
    }

    // ── SEURAT-KOKOELMA ──────────────────────────────────────────────────────

    match /seurat/{seuraId} {

      // Seura-dokumentin lukeminen:
      // - VP löytää oman seuransa kirjautumisen yhteydessä (resource.data.vp_uid)
      // - Seuran Admin löytää oman seuransa samoin
      allow read: if onSuperAdmin()
               || onSeuranVP(seuraId)
               || (onKirjautunut() && resource.data.vp_uid == request.auth.uid)
               || onSeuranAdmin(seuraId);

      // Seura-dokumentin kirjoitus: vain Super Admin
      allow write: if onSuperAdmin();

      // ── META ──────────────────────────────────────────────────────────────
      match /_meta/{doc} {
        allow read:  if onSuperAdmin() || onSeuranVP(seuraId) || onSeuranAdmin(seuraId);
        allow write: if onSuperAdmin();
      }

      // ── JOUKKUEET — Seuran Admin hallinnoi ───────────────────────────────
      // Joukkueet luodaan ennen pelaajia. Seuran Admin on vastuussa
      // joukkueiden luomisesta, muokkaamisesta ja poistamisesta.
      match /joukkueet/{joukkueId} {
        allow read:  if onSeuranJasen(seuraId);
        allow create: if onHallinnollinen(seuraId);
        allow update: if onHallinnollinen(seuraId);
        allow delete: if onSuperAdmin() || onSeuranAdmin(seuraId);
      }

      // ── PELAAJAT — Seuran Admin tuo, VP ja valmentajat lukevat ───────────
      // Pelaajaprofiilit tuodaan Excel-pohjasta. PalloID = dokumentti-ID.
      match /pelaajat/{palloId} {
        allow read:  if onSeuranJasen(seuraId);
        allow create: if onHallinnollinen(seuraId);
        allow update: if onHallinnollinen(seuraId);
        allow delete: if onSuperAdmin() || onSeuranAdmin(seuraId);
      }

      // ── KÄYTTÄJÄT — hallinnoidaan roolilistaa ────────────────────────────
      match /kayttajat/{kayttajaId} {
        // Käyttäjä näkee oman rivinsä
        allow read: if onKirjautunut() && request.auth.uid == kayttajaId;
        // VP ja Seuran Admin näkevät kaikki seuran käyttäjät
        allow read: if onHallinnollinen(seuraId);
        allow write: if onHallinnollinen(seuraId);
      }

      // ── KARTOITUKSET ──────────────────────────────────────────────────────
      match /kartoitukset/{kartoitusId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId)
                  || onSeuranAdmin(seuraId)
                  || (onSeuranJasen(seuraId) &&
                      get(/databases/$(database)/documents/seurat/$(seuraId)/kayttajat/$(request.auth.uid)).data.rooli
                      in ['testivastaava', 'fysiikkavalmentaja']);
      }

      // ── TESTIT (H-H-polku) ────────────────────────────────────────────────
      match /testit/{testiId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId)
                  || onSeuranAdmin(seuraId)
                  || (onSeuranJasen(seuraId) &&
                      get(/databases/$(database)/documents/seurat/$(seuraId)/kayttajat/$(request.auth.uid)).data.rooli
                      in ['testivastaava', 'fysiikkavalmentaja']);
      }

      // ── MUUT KOKOELMAT ────────────────────────────────────────────────────
      match /kirjaukset/{kirjausId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId);
      }

      match /tekniikka/{kilpailuId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId) || onSeuranAdmin(seuraId);
      }

      match /adar/{adarId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId);
      }

      match /kuorma/{kuormaId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranJasen(seuraId);
      }

      match /vammat/{vammaId} {
        allow read:  if onSuperAdmin() || onSeuranVP(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId);
      }
    }

    // ── VANHAT KOKOELMAT (yhteensopivuus) ────────────────────────────────────
    match /kirjaukset/{doc} {
      allow read, write: if onKirjautunut();
    }
    match /kirjaukset_joukkue/{doc} {
      allow read, write: if onKirjautunut();
    }
    match /kirjaukset_tapahtumat/{doc} {
      allow read, write: if onKirjautunut();
    }

    // ── PING-TESTI ────────────────────────────────────────────────────────────
    match /_ping/{doc} {
      allow read: if onKirjautunut();
    }
  }
}
