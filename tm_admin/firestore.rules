rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── APUFUNKTIOT ────────────────────────────────────────────────
    
    // Onko käyttäjä kirjautunut sisään?
    function onKirjautunut() {
      return request.auth != null;
    }
    
    // Onko käyttäjä super-admin?
    // Super-admin näkee kaikkien seurojen kaiken datan
    function onSuperAdmin() {
      return onKirjautunut() && 
             request.auth.token.superAdmin == true;
    }
    
    // Onko käyttäjä tämän seuran VP?
    // VP:n UID täsmää seura-dokumentin vp_uid-kenttään
    function onSeuranVP(seuraId) {
      return onKirjautunut() &&
             request.auth.uid == get(/databases/$(database)/documents/seurat/$(seuraId)).data.vp_uid;
    }
    
    // Onko käyttäjä tämän seuran jäsen missä tahansa roolissa?
    // Käytetään alikokoelmien suojaukseen
    function onSeuranJasen(seuraId) {
      return onKirjautunut() && (
        onSuperAdmin() ||
        onSeuranVP(seuraId) ||
        exists(/databases/$(database)/documents/seurat/$(seuraId)/kayttajat/$(request.auth.uid))
      );
    }

    // ── SEURAT-KOKOELMA ────────────────────────────────────────────
    // Seura-dokumentti: perustiedot, paketti, VP:n UID
    
    match /seurat/{seuraId} {
      // Super-admin näkee kaikki seurat
      // VP näkee vain oman seuransa
      // Muut eivät näe mitään
      allow read: if onSuperAdmin() || onSeuranVP(seuraId);
      
      // Vain super-admin voi luoda tai muokata seuradokumentteja
      // VP ei voi muokata oman seuransa perustietoja
      allow write: if onSuperAdmin();

      // ── SEURA-META ──────────────────────────────────────────────
      match /_meta/{doc} {
        allow read: if onSuperAdmin() || onSeuranVP(seuraId);
        allow write: if onSuperAdmin();
      }

      // ── JOUKKUEET ───────────────────────────────────────────────
      // Joukkueiden perustiedot ja valmentajat
      match /joukkueet/{joukkueId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId);
      }

      // ── KIRJAUKSET ──────────────────────────────────────────────
      // VP:n harjoitteluseurantakirjaukset
      // Vain seuran VP ja super-admin saavat kirjoittaa
      match /kirjaukset/{kirjausId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId);
      }

      // ── TESTIT ──────────────────────────────────────────────────
      // Mittaustulokset: nopeus, ketteryys, kevennyshyppy jne.
      // Testivastaava ja fysiikkavalmentaja voivat kirjoittaa
      match /testit/{testiId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranJasen(seuraId);
      }

      // ── KARTOITUKSET ────────────────────────────────────────────
      // Harjoitettavuuskartoitukset U12/U15/U19
      match /kartoitukset/{kartoitusId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranJasen(seuraId);
      }

      // ── TEKNIIKKAKILPAILUT ──────────────────────────────────────
      // Tekniikkakilpailutulokset
      match /tekniikka/{kilpailuId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranJasen(seuraId);
      }

      // ── ADAR ────────────────────────────────────────────────────
      // Game IQ ja ADAR-arvioinnit
      // Talenttivalmentaja kirjoittaa, muut lukevat
      match /adar/{adarId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId);
      }

      // ── KUORMASEURANTA ──────────────────────────────────────────
      // RPE ja kuormaseuranta
      match /kuorma/{kuormaId} {
        allow read:  if onSuperAdmin() || onSeuranJasen(seuraId);
        allow write: if onSuperAdmin() || onSeuranJasen(seuraId);
      }

      // ── VAMMAT ──────────────────────────────────────────────────
      // Vamma- ja kuntoutusdata — arkaluonteisin data
      // Vain fysioterapeutti, VP ja super-admin
      match /vammat/{vammaId} {
        allow read:  if onSuperAdmin() || onSeuranVP(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId);
      }

      // ── KÄYTTÄJÄT ───────────────────────────────────────────────
      // Seuran käyttäjät ja roolit
      // VP hallinnoi oman seuransa käyttäjiä
      match /kayttajat/{kayttajaId} {
        allow read:  if onSuperAdmin() || onSeuranVP(seuraId);
        allow write: if onSuperAdmin() || onSeuranVP(seuraId);
        
        // Käyttäjä näkee oman profiilinsa
        allow read: if onKirjautunut() && request.auth.uid == kayttajaId;
      }
    }

    // ── VANHAT KOKOELMAT (yhteensopivuus) ─────────────────────────
    // Nämä ovat v17:n rakentamat kokoelmat ennen seurahierarkiaa
    // Pidetään ne toiminnassa siirtymävaiheen ajan
    
    match /kirjaukset/{doc} {
      allow read, write: if onSuperAdmin() || onKirjautunut();
    }
    
    match /kirjaukset_joukkue/{doc} {
      allow read, write: if onSuperAdmin() || onKirjautunut();
    }
    
    match /kirjaukset_tapahtumat/{doc} {
      allow read, write: if onSuperAdmin() || onKirjautunut();
    }

    // ── PING (yhteyden testaus) ────────────────────────────────────
    match /_ping/{doc} {
      allow read: if onKirjautunut();
    }
  }
}
