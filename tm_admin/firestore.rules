rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Apufunktiot ────────────────────────────────────────────────────
    
    // Onko käyttäjä super-admin?
    function isSuperAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'talentmasterid@gmail.com';
    }
    
    // Onko käyttäjä kirjautunut?
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Onko käyttäjällä VP-custom-claim tälle seuralle?
    function isVP(seuraId) {
      return request.auth != null && (
        // Tapa 1: custom claim seuraId täsmää (uusi tapa, setup_demo_fc.js)
        (request.auth.token.seuraId == seuraId && request.auth.token.rooli == 'vp') ||
        // Tapa 2: super-admin näkee kaiken
        isSuperAdmin()
      );
    }
    
    // Onko käyttäjä tämän seuran jäsen (VP tai valmentaja)?
    function isSeuraJasen(seuraId) {
      return isVP(seuraId) || isSuperAdmin();
    }

    // ── Super-admin: lukee ja kirjoittaa kaiken ─────────────────────────
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── Admins-kokoelma ─────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // ── Seurat-kokoelma ─────────────────────────────────────────────────
    match /seurat/{seuraId} {
      // VP lukee oman seuransa perustiedot
      allow read: if isVP(seuraId);
      // Vain super-admin luo/muokkaa seura-dokumentteja
      allow write: if isSuperAdmin();

      // ── Alikokoelmat — VP:llä täysi pääsy oman seuran dataan ────────
      
      match /pelaajat/{pelaajaId} {
        allow read, write: if isVP(seuraId);
      }

      match /kartoitukset/{kartoitusId} {
        allow read, write: if isVP(seuraId);
      }

      match /kirjaukset/{kirjausId} {
        allow read, write: if isVP(seuraId);
      }

      match /joukkueet/{joukkueId} {
        allow read, write: if isVP(seuraId);
      }

      match /testit/{testiId} {
        allow read, write: if isVP(seuraId);
      }

      match /tekniikka/{tekniikkaId} {
        allow read, write: if isVP(seuraId);
      }

      match /adar/{adarId} {
        allow read, write: if isVP(seuraId);
      }

      match /kuorma/{kuormaId} {
        allow read, write: if isVP(seuraId);
      }

      // Vammat — arkaluonteinen terveystieto, vain VP ja super-admin
      match /vammat/{vammaId} {
        allow read, write: if isVP(seuraId);
      }

      match /kayttajat/{kayttajaId} {
        allow read, write: if isVP(seuraId);
      }
    }

    // ── Vanha rakenne (yhteensopivuus) ──────────────────────────────────
    match /kirjaukset/{doc} {
      allow read, write: if isSignedIn();
    }
    match /kirjaukset_joukkue/{doc} {
      allow read, write: if isSignedIn();
    }
    match /kirjaukset_tapahtumat/{doc} {
      allow read, write: if isSignedIn();
    }
  }
}
